# Copy to .streamlit/secrets.toml (gitignored) and fill in from the Supabase
# dashboard: Project Settings → API keys. The publishable key is the
# client-safe one (sb_publishable_...) — never put a service or Management
# API key here.
[supabase]
url = "https://<project-ref>.supabase.co"
publishable_key = "sb_publishable_..."
